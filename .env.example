# Supabase (server)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase (frontend — same values, VITE_ prefix required by Vite)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# S3-compatible storage (cloud.ru or Cloudflare R2)
# For cloud.ru: credentials are sent as "tenant_id:access_key"
# CORS must be configured on the bucket to allow GET/HEAD from CORS_ORIGIN
# AllowedOrigins: your domain, AllowedMethods: GET/HEAD, AllowedHeaders: *
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central-1
S3_BUCKET=homework-attachments
S3_TENANT_ID=xxx
S3_ACCESS_KEY=xxx
S3_SECRET_KEY=xxx

# Scraper
SCRAPE_CRON=0 6 * * 1-5
PLAYWRIGHT_STATE_PATH=./state/classroom_state.json

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-xxx
TELEGRAM_ADMIN_ID=123456789

# API
API_PORT=3000
CORS_ORIGIN=http://localhost:5173

# OpenRouter (future)
OPENROUTER_API_KEY=sk-or-xxx
